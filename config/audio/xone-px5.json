{
  "name": "Allen & Heath XONE:PX5",
  "mode": "jack",
  "jack": {
    "cardNameIncludes": "XONE",
    "sampleRate": 48000,
    "periodSize": 128,
    "periods": 2,
    "capturePortPairs": [
      {
        "id": "main",
        "label": "PX5 Send",
        "ports": ["system:capture_9", "system:capture_10"]
      },
      {
        "id": "ch2",
        "label": "PX5 Channel 2",
        "ports": ["system:capture_3", "system:capture_4"]
      },
      {
        "id": "ch3",
        "label": "PX5 Channel 3",
        "ports": ["system:capture_5", "system:capture_6"]
      }
    ],
    "playbackPorts": ["system:playback_1", "system:playback_2"]
  },
  "pd": {
    "darwin": { "adc": [9, 10], "dac": [1, 2] },
    "linux": { "adc": [1, 2], "dac": [1, 2] }
  }
}
