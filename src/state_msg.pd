#N canvas 0 0 450 300 12;
#X obj 50 30 inlet;
#X obj 50 250 outlet;
#X obj 50 120 list prepend #1;
#X obj 50 200 print STATE_MSG_OUT;
#X text 200 30 state_msg: formats "slotname state" messages;
#X text 200 50 Usage: [state_msg slot1];
#X text 200 70 Input: symbol (recording/stopped/playing/paused);
#X text 200 90 Output: list (slot1 recording);
#X connect 0 0 2 0;
#X connect 2 0 3 0;
#X connect 2 0 1 0;
